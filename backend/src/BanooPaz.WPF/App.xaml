<Application x:Class="BanooPaz.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BanooPaz.WPF"
             >
    <Application.Resources>
        <FontFamily x:Key="AppFontFamily">pack://application:,,,/Fonts/Vazir/#Vazir</FontFamily>

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style TargetType="{x:Type Control}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </Application.Resources>
</Application>
