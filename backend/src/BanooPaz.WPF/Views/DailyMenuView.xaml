<UserControl x:Class="BanooPaz.WPF.Views.DailyMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BanooPaz.WPF.Controls"
             xmlns:converters="clr-namespace:BanooPaz.WPF.Converters"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:ThousandsSeparatorConverter x:Key="ThousandsSeparatorConverter" />
        <Style x:Key="DailyMenuOperationButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#6D2E2E" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="DailyMenuDeleteButton" TargetType="Button" BasedOn="{StaticResource DailyMenuOperationButton}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Background" Value="#B3261E" />
        </Style>
        <Style x:Key="ModalFormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4F3833" />
        </Style>
        <Style x:Key="ModalFormInput" TargetType="Control">
            <Setter Property="Height" Value="42" />
            <Setter Property="Width" Value="260" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="تاریخ منو" VerticalAlignment="Center" Margin="4"/>
                    <controls:PersianDatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Margin="4"/>
                    <Button Content="جستجو" Command="{Binding RefreshCommand}" Margin="10,4,4,4"/>
                    <Button Content="افزودن" Command="{Binding OpenAddItemPopupCommand}" Margin="4"/>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B00020" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#287A3D" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#FFF3EC" BorderBrush="#E4CFC4" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock Text="آیتم‌های منوی روزانه" FontSize="18" FontWeight="SemiBold" Foreground="#6D2E2E"/>
                    <TextBlock Text="{Binding Items.Count, StringFormat=تعداد: {0}}" Foreground="#765B55" HorizontalAlignment="Left"/>
                </DockPanel>
            </Border>

            <DataGrid Grid.Row="3" ItemsSource="{Binding Items}" IsReadOnly="True" CanUserAddRows="False" RowHeight="46">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="غذا" Binding="{Binding FoodName}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="قیمت امروز" Binding="{Binding Price, Converter={StaticResource ThousandsSeparatorConverter}, UpdateSourceTrigger=LostFocus}" Width="130"/>
                    <DataGridTextColumn Header="ظرفیت پرس" Binding="{Binding CapacityPortions}" Width="120"/>
                    <DataGridTextColumn Header="فروخته‌شده" Binding="{Binding SoldPortions}" IsReadOnly="True" Width="110"/>
                    <DataGridTextColumn Header="باقی‌مانده" Binding="{Binding RemainingPortions}" IsReadOnly="True" Width="110"/>
                    <DataGridTemplateColumn Header="عملیات" Width="170">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate>
                            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="ویرایش"
                                        Style="{StaticResource DailyMenuOperationButton}"
                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="حذف"
                                        Style="{StaticResource DailyMenuDeleteButton}"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </WrapPanel>
                        </DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Visibility="{Binding IsAddItemPopupVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#99000000" />

            <Border Background="White"
                    BorderBrush="#E4CFC4"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24"
                    Width="620"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding PopupTitle}" FontSize="22" FontWeight="SemiBold" Foreground="#6D2E2E"/>
                            <WrapPanel Margin="0,10,0,0">
                                <TextBlock Text="تاریخ منو" VerticalAlignment="Center" Foreground="#765B55" Margin="4"/>
                                <controls:PersianDatePicker SelectedDate="{Binding SelectedDate}" IsEnabled="False" Margin="4"/>
                            </WrapPanel>
                        </StackPanel>
                        <Button Content="×"
                                Grid.Column="1"
                                Command="{Binding CloseAddItemPopupCommand}"
                                Width="42"
                                Height="36"
                                Padding="0"
                                FontSize="22"
                                HorizontalAlignment="Left"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B00020" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="غذا" Style="{StaticResource ModalFormLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableFoods}" SelectedItem="{Binding SelectedFoodToAdd}"
                                  Grid.Row="0" Grid.Column="1"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding IsFoodSelectionEnabled}"
                                  Style="{StaticResource ModalFormInput}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="قیمت امروز" Style="{StaticResource ModalFormLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource ModalFormInput}"
                                 Text="{Binding PriceToAdd, Converter={StaticResource ThousandsSeparatorConverter}, UpdateSourceTrigger=PropertyChanged}"
                                 FlowDirection="LeftToRight"
                                 TextAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="ظرفیت" Style="{StaticResource ModalFormLabel}"/>
                        <TextBox Text="{Binding CapacityToAdd, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="2" Grid.Column="1"
                                 Style="{StaticResource ModalFormInput}"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="فعال است؟"
                                   Style="{StaticResource ModalFormLabel}"
                                   Visibility="{Binding IsEditingItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <CheckBox Grid.Row="3"
                                  Grid.Column="1"
                                  IsChecked="{Binding ItemIsAvailableForEdit}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,14"
                                  Visibility="{Binding IsEditingItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <WrapPanel Grid.Row="4"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   HorizontalAlignment="Left"
                                   FlowDirection="RightToLeft"
                                   Margin="0,4,0,0">
                            <Button Content="{Binding PopupSubmitText}" Command="{Binding SavePopupItemCommand}"/>
                            <Button Content="انصراف" Command="{Binding CloseAddItemPopupCommand}" Background="#765B55"/>
                        </WrapPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
