<UserControl x:Class="BanooPaz.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="MinHeight" Value="115" />
        </Style>
        <Style x:Key="MetricTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#76514A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6D2E2E" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="#FFF3EC" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Right">
                        <TextBlock Text="داشبورد امروز" FontSize="22" FontWeight="SemiBold" Foreground="#6D2E2E" />
                        <TextBlock Text="{Binding LastLoadedText}" Foreground="#76514A" Margin="0,6,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="در حال دریافت..." Foreground="#8B3A3A" FontWeight="SemiBold"
                                   Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="تازه‌سازی داشبورد" Command="{Binding RefreshCommand}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#B00020" TextWrapping="Wrap" Margin="0,0,0,10" />

            <UniformGrid Columns="4">
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="کل سفارش‌های امروز" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.TotalOrders, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="سفارش‌های فعال" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.ActiveOrders, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="تعداد پرس‌ها" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.TotalPortions, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="فروش ناخالص غیرلغوشده" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.GrossSales, StringFormat={}{0:N0}, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="در انتظار تایید" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.PendingOrders, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="در حال آماده‌سازی" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.PreparingOrders, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="آماده تحویل" />
                        <TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.ReadyOrders, TargetNullValue=0}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricTitle}" Text="تحویل‌شده / لغوشده" />
                        <TextBlock Style="{StaticResource MetricValue}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N0} / {1:N0}">
                                    <Binding Path="Summary.DeliveredOrders" TargetNullValue="0" />
                                    <Binding Path="Summary.CancelledOrders" TargetNullValue="0" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="White" CornerRadius="10" Padding="18" Margin="0,8,12,0">
                <StackPanel>
                    <TextBlock Text="وضعیت منوی امروز" FontSize="18" FontWeight="SemiBold" Foreground="#6D2E2E" />
                    <WrapPanel Margin="0,12,0,0">
                        <TextBlock Text="وضعیت: " Foreground="#76514A" />
                        <TextBlock Text="{Binding MenuStatusText}" FontWeight="SemiBold" Foreground="#287A3D" Margin="0,0,22,0" />
                        <TextBlock Text="تعداد آیتم‌ها: " Foreground="#76514A" />
                        <TextBlock Text="{Binding Summary.TodayMenuItems, TargetNullValue=0}" FontWeight="SemiBold" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
