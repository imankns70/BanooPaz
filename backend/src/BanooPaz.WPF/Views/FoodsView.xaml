<UserControl x:Class="BanooPaz.WPF.Views.FoodsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="فهرست غذاها" FontSize="20" FontWeight="SemiBold" Foreground="#6D2E2E" VerticalAlignment="Center"/>
                <Button Content="تازه‌سازی" Command="{Binding RefreshCommand}" HorizontalAlignment="Left"/>
            </DockPanel>
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B00020" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#287A3D" TextWrapping="Wrap"/>
            </StackPanel>
            <DataGrid Grid.Row="2" ItemsSource="{Binding Foods}" SelectedItem="{Binding SelectedFood, Mode=TwoWay}" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="نام غذا" Binding="{Binding Name}" Width="*"/>
                    <DataGridCheckBoxColumn Header="فعال؟" Binding="{Binding IsActive}" Width="70"/>
                    <DataGridTextColumn Header="توضیح" Binding="{Binding Description}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="18">
            <StackPanel>
                <TextBlock Text="ویرایش غذا" FontSize="20" FontWeight="SemiBold" Foreground="#6D2E2E" Margin="0,0,0,14"/>
                <TextBlock Text="نام غذا"/><TextBox Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" Padding="8"/>
                <TextBlock Text="توضیح"/><TextBox Text="{Binding FoodDescription}" Margin="0,4,0,10" Padding="8" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                <TextBlock Text="آدرس عکس"/><TextBox Text="{Binding ImageUrl}" Margin="0,4,0,10" Padding="8" FlowDirection="LeftToRight"/>
                <CheckBox Content="فعال" IsChecked="{Binding IsActive}" Margin="0,5,0,14"/>
                <WrapPanel>
                    <Button Content="جدید" Command="{Binding NewFoodCommand}"/>
                    <Button Content="ذخیره" Command="{Binding SaveFoodCommand}"/>
                    <Button Content="فعال/غیرفعال" Command="{Binding ToggleActiveCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
