<UserControl x:Class="BanooPaz.WPF.Views.ManualOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BanooPaz.WPF.Controls"
             FlowDirection="RightToLeft">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="520" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="3*" MinWidth="620" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="ثبت دستی سفارش" FontSize="20" FontWeight="SemiBold" Foreground="#6D2E2E" Margin="0,0,0,14" />

                    <TextBlock Text="نام مشتری" />
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,4,0,10" />

                    <TextBlock Text="شماره تماس" />
                    <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,4,0,10" />

                    <TextBlock Text="روش دریافت" />
                    <ComboBox ItemsSource="{Binding DeliveryMethods}"
                              SelectedItem="{Binding SelectedDeliveryMethod}"
                              DisplayMemberPath="DisplayName"
                              Padding="6"
                              Margin="0,4,0,10" />

                    <TextBlock Text="روش پرداخت" />
                    <ComboBox ItemsSource="{Binding PaymentMethods}"
                              SelectedItem="{Binding SelectedPaymentMethod}"
                              DisplayMemberPath="DisplayName"
                              Padding="6"
                              Margin="0,4,0,10" />

                    <TextBlock Text="آدرس" />
                    <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}" Padding="8" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,10" />

                    <TextBlock Text="یادداشت مشتری" />
                    <TextBox Text="{Binding CustomerNote}" Padding="8" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,14" />

                    <WrapPanel>
                        <Button Content="ثبت سفارش" Command="{Binding SubmitOrderCommand}" />
                        <Button Content="سفارش جدید" Command="{Binding NewOrderCommand}" />
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="تاریخ منو" VerticalAlignment="Center" Margin="4" />
                    <controls:PersianDatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Margin="4" />
                    <Button Content="بارگذاری منو" Command="{Binding LoadMenuCommand}" />
                    <TextBlock Text="غذا" VerticalAlignment="Center" Margin="12,4,4,4" />
                    <ComboBox ItemsSource="{Binding MenuItems}"
                              SelectedItem="{Binding SelectedMenuItem}"
                              DisplayMemberPath="DisplayName"
                              Width="340"
                              Margin="4" />
                    <TextBlock Text="تعداد" VerticalAlignment="Center" Margin="12,4,4,4" />
                    <TextBox Text="{Binding QuantityToAdd, UpdateSourceTrigger=PropertyChanged}" Width="55" Padding="6" Margin="4" />
                    <Button Content="افزودن" Command="{Binding AddItemCommand}" />
                </WrapPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B00020" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#287A3D" TextWrapping="Wrap" />
            </StackPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Lines}" IsReadOnly="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="غذا" Binding="{Binding FoodName}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="قیمت" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" IsReadOnly="True" Width="100" />
                    <DataGridTextColumn Header="تعداد" Binding="{Binding Quantity}" Width="80" />
                    <DataGridTextColumn Header="جمع" Binding="{Binding TotalPrice, StringFormat={}{0:N0}}" IsReadOnly="True" Width="110" />
                    <DataGridTemplateColumn Header="عملیات" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="حذف"
                                        Background="#A51D2D"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="#FFF3EC" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                <DockPanel>
                    <TextBlock Text="جمع کل سفارش" FontSize="16" FontWeight="SemiBold" Foreground="#6D2E2E" />
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0}}" FontSize="20" FontWeight="SemiBold" Foreground="#6D2E2E" HorizontalAlignment="Left" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
