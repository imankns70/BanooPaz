<UserControl x:Class="Kafgir.WPF.Controls.PaginationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding TotalItemsText}"
                   Style="{StaticResource MutedText}"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Button Content="قبلی"
                    Command="{Binding PreviousPageCommand}"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="64" MinHeight="32" Padding="10,4" />
            <Border Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    MinWidth="92"
                    Margin="4,0"
                    Padding="10,5">
                <TextBlock Text="{Binding PageText}"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <Button Content="بعدی"
                    Command="{Binding NextPageCommand}"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="64" MinHeight="32" Padding="10,4" />
        </StackPanel>
    </Grid>
</UserControl>
