<Window x:Class="Kafgir.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Kafgir.WPF.Converters"
        xmlns:views="clr-namespace:Kafgir.WPF.Views"
        Title="کفگیر - پنل مدیریت"
        Width="1450" Height="850" MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F4" FlowDirection="RightToLeft"
        FontFamily="{StaticResource AppFontFamily}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:SelectedIndexToVisibilityConverter x:Key="SelectedIndexToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="#8B3A3A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AlternatingRowBackground" Value="#FFF3EC" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="BorderBrush" Value="#E4CFC4" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="RowHeight" Value="36" />
        </Style>
        <Style x:Key="SidebarListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="SidebarItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#FFE5D7" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#7D3838" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF3EC" />
                                <Setter Property="Foreground" Value="#6D2E2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <views:LoginView DataContext="{Binding Login}"
                         Visibility="{Binding DataContext.IsAuthenticated, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"
              FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1"
                    Background="#6D2E2E"
                    CornerRadius="12"
                    Padding="18"
                    Margin="14,0,0,0"
                    FlowDirection="RightToLeft">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,28">
                        <TextBlock Text="کفگیر"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="پنل مدیریت"
                                   Foreground="#FFE5D7"
                                   FontSize="14"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom"
                               Text="مدیریت سفارش‌ها، غذاها و منوی روزانه"
                               Foreground="#FFE5D7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,18,0,0" />

                    <ListBox Style="{StaticResource SidebarListBox}"
                             ItemContainerStyle="{StaticResource SidebarItem}"
                             SelectedIndex="{Binding SelectedNavigationIndex, Mode=TwoWay}">
                        <ListBoxItem Content="داشبورد" />
                        <ListBoxItem Content="سفارش‌ها" />
                        <ListBoxItem Content="ثبت سفارش" />
                        <ListBoxItem Content="غذاها" />
                        <ListBoxItem Content="منوی روزانه" />
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="0" FlowDirection="RightToLeft">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="18,12" Background="White" CornerRadius="8" Margin="0,0,0,14">
                    <DockPanel>
                        <TextBlock Text="کفگیر - پنل مدیریت" Foreground="#6D2E2E"
                                   FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="داشبورد، سفارش‌ها، غذاها و منوی روزانه" Foreground="#765B55"
                                   FontSize="13" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <views:DashboardView DataContext="{Binding Dashboard}"
                                         Visibility="{Binding DataContext.SelectedNavigationIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SelectedIndexToVisibilityConverter}, ConverterParameter=0}" />
                    <views:OrdersView DataContext="{Binding Orders}"
                                      Visibility="{Binding DataContext.SelectedNavigationIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SelectedIndexToVisibilityConverter}, ConverterParameter=1}" />
                    <views:ManualOrderView DataContext="{Binding ManualOrder}"
                                           Visibility="{Binding DataContext.SelectedNavigationIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SelectedIndexToVisibilityConverter}, ConverterParameter=2}" />
                    <views:FoodsView DataContext="{Binding Foods}"
                                     Visibility="{Binding DataContext.SelectedNavigationIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SelectedIndexToVisibilityConverter}, ConverterParameter=3}" />
                    <views:DailyMenuView DataContext="{Binding DailyMenu}"
                                         Visibility="{Binding DataContext.SelectedNavigationIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SelectedIndexToVisibilityConverter}, ConverterParameter=4}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
