<UserControl x:Class="Kafgir.WPF.Views.DailyMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Kafgir.WPF.Converters"
             xmlns:controls="clr-namespace:Kafgir.WPF.Controls"
             xmlns:views="clr-namespace:Kafgir.WPF.Views"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:ThousandsSeparatorConverter x:Key="ThousandsSeparatorConverter" />

        <Style x:Key="DailyMenuOperationButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="DailyMenuDeleteButton" TargetType="Button" BasedOn="{StaticResource DailyMenuOperationButton}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        </Style>
        <Style x:Key="DailyMenuBodyCell" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="SummaryLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="SummaryValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="21" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SurfaceCard}"
                Padding="20,17"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="مدیریت امروز"
                               Foreground="{StaticResource BrandBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock Text="منوی روزانه"
                               Style="{StaticResource PageTitle}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding CurrentDateText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center">
                    <Border Background="{StaticResource BrandSoftBrush}"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,8"
                            Margin="4">
                        <CheckBox Content="سفارش‌گیری امروز باز است"
                                  IsChecked="{Binding IsOpen, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Margin="0" />
                    </Border>
                    <TextBlock Text="ذخیره نشده"
                               Foreground="{StaticResource WarningBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="در حال بروزرسانی..."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="ذخیره وضعیت"
                            Command="{Binding SaveMenuCommand}"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="112" />
                    <Button Content="افزودن غذا"
                            Command="{Binding OpenItemFormCommand}"
                            MinWidth="112" />
                </WrapPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Text="غذاهای منو" Style="{StaticResource SummaryLabel}" />
                    <TextBlock Text="{Binding Items.Count, TargetNullValue=0}" Style="{StaticResource SummaryValue}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Text="ظرفیت کل" Style="{StaticResource SummaryLabel}" />
                    <TextBlock Text="{Binding TotalCapacity, TargetNullValue=0}" Style="{StaticResource SummaryValue}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCard}">
                <StackPanel>
                    <TextBlock Text="فروخته‌شده" Style="{StaticResource SummaryLabel}" />
                    <TextBlock Text="{Binding TotalSold, TargetNullValue=0}" Style="{StaticResource SummaryValue}" Foreground="{StaticResource BrandBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="باقی‌مانده" Style="{StaticResource SummaryLabel}" />
                    <TextBlock Text="{Binding TotalRemaining, TargetNullValue=0}" Style="{StaticResource SummaryValue}" Foreground="{StaticResource SageBrush}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Border Background="{StaticResource DangerSoftBrush}"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="12,8"
                    Margin="0,0,0,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" />
            </Border>
            <Border Background="{StaticResource SuccessSoftBrush}"
                    BorderBrush="#BBF7D0"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="12,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SageBrush}" TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <views:DailyMenuItemFormView Grid.Row="3"
                                     Visibility="{Binding IsItemFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border Grid.Row="4"
                Style="{StaticResource SurfaceCard}"
                Padding="16,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <DataGrid ItemsSource="{Binding ItemsPagination.Items}"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              RowHeight="50"
                              CellStyle="{StaticResource DailyMenuBodyCell}"
                              BorderThickness="0"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="غذا" Binding="{Binding FoodName}" Width="*" />
                            <DataGridTextColumn Header="قیمت امروز" Binding="{Binding Price, Converter={StaticResource ThousandsSeparatorConverter}}" Width="135" />
                            <DataGridTextColumn Header="ظرفیت" Binding="{Binding CapacityPortions}" Width="100" />
                            <DataGridTextColumn Header="فروخته" Binding="{Binding SoldPortions}" Width="100" />
                            <DataGridTextColumn Header="باقی‌مانده" Binding="{Binding RemainingPortions}" Width="105" />
                            <DataGridCheckBoxColumn Header="فعال" Binding="{Binding IsAvailable}" Width="72" />
                            <DataGridTemplateColumn Header="عملیات" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="ویرایش"
                                                    Style="{StaticResource DailyMenuOperationButton}"
                                                    Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="حذف"
                                                    Style="{StaticResource DailyMenuDeleteButton}"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </WrapPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource BrandSoftBrush}" Margin="0,0,0,10">
                            <TextBlock Text="+" Foreground="{StaticResource BrandBrush}" FontSize="24"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="هنوز غذایی برای امروز اضافه نشده است."
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="از دکمه «افزودن غذا» استفاده کنید."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <controls:PaginationControl Grid.Row="1" DataContext="{Binding ItemsPagination}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
