<UserControl x:Class="Kafgir.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Kafgir.WPF.Converters"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="MinHeight" Value="100" />
        </Style>
        <Style x:Key="MetricTitle" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,12">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Right">
                        <TextBlock Text="داشبورد امروز" Style="{StaticResource PageTitle}" />
                        <TextBlock Text="{Binding LastLoadedText}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="در حال دریافت..."
                                   Foreground="{StaticResource BrandBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="تازه‌سازی" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Background="{StaticResource DangerSoftBrush}"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,7"
                    Margin="0,0,0,10"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" />
            </Border>

            <UniformGrid Columns="4">
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="کل سفارش‌های امروز" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.TotalOrders, TargetNullValue=0}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="سفارش‌های فعال" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.ActiveOrders, TargetNullValue=0}" Foreground="{StaticResource BrandBrush}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="تعداد پرس‌ها" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.TotalPortions, TargetNullValue=0}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="فروش ناخالص غیرلغوشده" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.GrossSales, StringFormat={}{0:N0}, TargetNullValue=0}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="در انتظار تایید" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.PendingOrders, TargetNullValue=0}" Foreground="{StaticResource WarningBrush}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="در حال آماده‌سازی" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.PreparingOrders, TargetNullValue=0}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="آماده تحویل" /><TextBlock Style="{StaticResource MetricValue}" Text="{Binding Summary.ReadyOrders, TargetNullValue=0}" /></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Style="{StaticResource MetricTitle}" Text="تحویل‌شده / لغوشده" /><TextBlock Style="{StaticResource MetricValue}"><TextBlock.Text><MultiBinding StringFormat="{}{0:N0} / {1:N0}"><Binding Path="Summary.DeliveredOrders" TargetNullValue="0" /><Binding Path="Summary.CancelledOrders" TargetNullValue="0" /></MultiBinding></TextBlock.Text></TextBlock></StackPanel></Border>
            </UniformGrid>

            <Border Style="{StaticResource SurfaceCard}" Margin="0,2,10,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right">
                        <TextBlock Text="وضعیت منوی امروز" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="وضعیت سفارش‌گیری و تعداد غذاهای فعال" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Border Background="{StaticResource SuccessSoftBrush}" CornerRadius="7" Padding="10,6" Margin="0,0,10,0">
                            <TextBlock Text="{Binding MenuStatusText}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="7" Padding="10,6">
                            <TextBlock Text="{Binding Summary.TodayMenuItems, StringFormat=تعداد غذا: {0}, TargetNullValue=تعداد غذا: 0}" FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
