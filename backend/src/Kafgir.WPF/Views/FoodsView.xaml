<UserControl x:Class="Kafgir.WPF.Views.FoodsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Kafgir.WPF.Controls"
             FlowDirection="RightToLeft">
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding SearchFoodsCommand}" />
    </UserControl.InputBindings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SurfaceCard}" Padding="14">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Border Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                    <DockPanel>
                        <Button Content="جستجو"
                                Command="{Binding SearchFoodsCommand}"
                                DockPanel.Dock="Left"
                                MinWidth="82" />
                        <TextBox Text="{Binding FoodNameSearch, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"
                                 ToolTip="جستجو بر اساس نام غذا" />
                    </DockPanel>
                </Border>
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <DataGrid Grid.Row="2" ItemsSource="{Binding FoodsPagination.Items}" SelectedItem="{Binding SelectedFood, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نام غذا" Binding="{Binding Name}" Width="*" />
                        <DataGridCheckBoxColumn Header="فعال" Binding="{Binding IsActive}" Width="70" />
                        <DataGridTextColumn Header="توضیح" Binding="{Binding Description}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
                <controls:PaginationControl Grid.Row="3" DataContext="{Binding FoodsPagination}" />
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource SurfaceCard}">
            <StackPanel>
                <TextBlock Text="ویرایش غذا" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                <TextBlock Text="مشخصات غذا را ثبت یا بروزرسانی کنید." Style="{StaticResource MutedText}" Margin="0,0,0,16" />
                <TextBlock Text="نام غذا" Style="{StaticResource FormLabel}" />
                <TextBox Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                <TextBlock Text="توضیح" Style="{StaticResource FormLabel}" />
                <TextBox Text="{Binding FoodDescription}" Margin="0,0,0,10" Height="74" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />
                <TextBlock Text="آدرس عکس" Style="{StaticResource FormLabel}" />
                <TextBox Text="{Binding ImageUrl}" Margin="0,0,0,10" FlowDirection="LeftToRight" />
                <CheckBox Content="غذا فعال است" IsChecked="{Binding IsActive}" Margin="0,3,0,14" />
                <WrapPanel>
                    <Button Content="ذخیره" Command="{Binding SaveFoodCommand}" MinWidth="84" />
                    <Button Content="جدید" Command="{Binding NewFoodCommand}" Style="{StaticResource SecondaryButton}" MinWidth="74" />
                    <Button Content="تغییر وضعیت" Command="{Binding ToggleActiveCommand}" Style="{StaticResource GhostButton}" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
