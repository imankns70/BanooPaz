<UserControl x:Class="Kafgir.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Kafgir.WPF.Converters"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/login-food-background.png"
                        Stretch="UniformToFill"
                        Opacity="0.32" />
        </Grid.Background>
        <Rectangle Fill="#FFF8F4" Opacity="0.54" />
        <Border Width="420"
                Padding="28"
                Background="#F9FFFFFF"
                BorderBrush="#E4CFC4"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ورود مدیر"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#6D2E2E"
                           Margin="0,0,0,6" />
                <TextBlock Text="برای ورود به پنل مدیریت کفگیر، نام کاربری و رمز عبور را وارد کنید."
                           Foreground="#765B55"
                           TextWrapping="Wrap"
                           Margin="0,0,0,22" />

                <Border Background="#FFF3EC"
                        BorderBrush="#E4CFC4"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,14"
                        Visibility="{Binding ConnectionMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectionMessage}"
                                   Foreground="#8B3A3A"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <Button Content="بررسی دوباره اتصال"
                                Command="{Binding CheckConnectionCommand}"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <TextBlock Text="نام کاربری" Margin="0,0,0,6" Foreground="#4D3430" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         FontSize="15"
                         Margin="0,0,0,14" />

                <TextBlock Text="رمز عبور" Margin="0,0,0,6" Foreground="#4D3430" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="PasswordInput"
                                 Grid.Column="0"
                                 Padding="10"
                                 FontSize="15"
                                 PasswordChanged="PasswordInput_OnPasswordChanged"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <TextBox x:Name="VisiblePasswordInput"
                             Grid.Column="0"
                             Padding="10"
                             FontSize="15"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ToggleButton Grid.Column="1"
                                  Width="76"
                                  Margin="8,0,0,0"
                                  IsChecked="{Binding IsPasswordVisible, Mode=TwoWay}"
                                  Checked="PasswordVisibilityToggle_OnChanged"
                                  Unchecked="PasswordVisibilityToggle_OnChanged">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="نمایش" />
                                <Setter Property="Padding" Value="10,7" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="مخفی" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#B3261E"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <Button Content="ورود"
                        Command="{Binding LoginCommand}"
                        Padding="14,10"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
