<UserControl x:Class="Kafgir.WPF.Views.ManualOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4F3833" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="FormInput" TargetType="Control">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style x:Key="QuantityButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="#6D2E2E" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="DangerOperationButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#B3261E" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#B00020" TextWrapping="Wrap" FontSize="15" />
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#287A3D" TextWrapping="Wrap" FontSize="15" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="اطلاعات مشتری" FontSize="20" FontWeight="SemiBold" Foreground="#6D2E2E" Margin="0,0,0,16" />

                            <TextBlock Text="نام مشتری" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInput}" />

                            <TextBlock Text="شماره تماس" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInput}" />

                            <TextBlock Text="روش دریافت" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding DeliveryMethods}"
                                      SelectedItem="{Binding SelectedDeliveryMethod}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource FormInput}" />

                            <TextBlock Text="روش پرداخت" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding PaymentMethods}"
                                      SelectedItem="{Binding SelectedPaymentMethod}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource FormInput}" />

                            <TextBlock Text="آدرس" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                     Height="76"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="یادداشت مشتری" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding CustomerNote}"
                                     Padding="8"
                                     Height="76"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,16" />

                            <WrapPanel HorizontalAlignment="Left" FlowDirection="RightToLeft">
                                <Button Content="ثبت سفارش" Command="{Binding SubmitOrderCommand}" MinWidth="110" />
                                <Button Content="سفارش جدید" Command="{Binding NewOrderCommand}" Background="#765B55" MinWidth="105" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="افزودن غذا از منوی امروز"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#6D2E2E"
                                   Margin="0,0,0,14" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,0,0">
                                <TextBlock Text="غذا" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding MenuItems}"
                                          SelectedItem="{Binding SelectedMenuItem}"
                                          DisplayMemberPath="DisplayName"
                                          Height="42"
                                          Padding="8"
                                          FontSize="15" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0">
                                <TextBlock Text="تعداد" Style="{StaticResource FieldLabel}" />
                                <WrapPanel FlowDirection="LeftToRight" HorizontalAlignment="Right">
                                    <Button Content="−" Style="{StaticResource QuantityButton}" Command="{Binding DecreaseQuantityToAddCommand}" />
                                    <Border Width="48" Height="34" Background="#FFF3EC" BorderBrush="#E4CFC4" BorderThickness="1" CornerRadius="6" Margin="3,0">
                                        <TextBlock Text="{Binding QuantityToAdd}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2E1F1B" />
                                    </Border>
                                    <Button Content="+" Style="{StaticResource QuantityButton}" Command="{Binding IncreaseQuantityToAddCommand}" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text=" " Style="{StaticResource FieldLabel}" />
                                <Button Content="افزودن" Command="{Binding AddItemCommand}" Height="42" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="آیتم‌های سفارش" FontSize="20" FontWeight="SemiBold" Foreground="#6D2E2E" />
                            <TextBlock Text="{Binding Lines.Count, StringFormat=تعداد ردیف: {0}}" Foreground="#765B55" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </DockPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Lines}" IsReadOnly="True" CanUserAddRows="False" RowHeight="46">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="غذا" Binding="{Binding FoodName}" IsReadOnly="True" Width="*" />
                                <DataGridTextColumn Header="قیمت" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" IsReadOnly="True" Width="105" />
                                <DataGridTemplateColumn Header="تعداد" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <WrapPanel FlowDirection="LeftToRight" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="−"
                                                        Style="{StaticResource QuantityButton}"
                                                        Command="{Binding DataContext.DecreaseLineQuantityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                                <Border Width="42" Height="30" Background="#FFF3EC" BorderBrush="#E4CFC4" BorderThickness="1" CornerRadius="6" Margin="3,0">
                                                    <TextBlock Text="{Binding Quantity}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Foreground="#2E1F1B" />
                                                </Border>
                                                <Button Content="+"
                                                        Style="{StaticResource QuantityButton}"
                                                        Command="{Binding DataContext.IncreaseLineQuantityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </WrapPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="جمع" Binding="{Binding TotalPrice, StringFormat={}{0:N0}}" IsReadOnly="True" Width="115" />
                                <DataGridTemplateColumn Header="عملیات" Width="92">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="حذف"
                                                    Style="{StaticResource DangerOperationButton}"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#FFF3EC" CornerRadius="12" Padding="16" BorderBrush="#E4CFC4" BorderThickness="1">
                    <DockPanel>
                        <TextBlock Text="جمع کل سفارش" FontSize="18" FontWeight="SemiBold" Foreground="#6D2E2E" />
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} تومان}" FontSize="24" FontWeight="Bold" Foreground="#6D2E2E" HorizontalAlignment="Left" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
