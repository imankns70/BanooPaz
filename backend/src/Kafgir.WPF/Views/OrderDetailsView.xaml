<UserControl x:Class="Kafgir.WPF.Views.OrderDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Kafgir.WPF.Converters"
             xmlns:controls="clr-namespace:Kafgir.WPF.Controls"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <converters:OrderStatusToPersianConverter x:Key="OrderStatusConverter" />
        <converters:PaymentMethodToPersianConverter x:Key="PaymentMethodConverter" />
        <converters:OrderStatusActionVisibilityConverter x:Key="OrderStatusActionVisibilityConverter" />
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="8,4" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="جزئیات سفارش" Style="{StaticResource SectionTitle}" />
            <TextBlock Text="اطلاعات مشتری، اقلام و تاریخچه وضعیت" Style="{StaticResource MutedText}" Margin="0,3,0,12" />

            <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="12">
                <Grid DataContext="{Binding Details.Order}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="شماره سفارش" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Column="1" Text="{Binding OrderNumber}" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="1" Text="نام مشتری" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CustomerFullName}" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="2" Text="شماره تماس" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CustomerPhoneNumber}" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="3" Text="آدرس" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AddressLine}" TextWrapping="Wrap" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="4" Text="توضیح مشتری" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CustomerNote}" TextWrapping="Wrap" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="5" Text="توضیح ادمین" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding AdminNote}" TextWrapping="Wrap" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="6" Text="وضعیت" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Status, Converter={StaticResource OrderStatusConverter}}" Style="{StaticResource DetailValue}" Foreground="{StaticResource BrandBrush}" />
                    <TextBlock Grid.Row="7" Text="روش پرداخت" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PaymentMethod, Converter={StaticResource PaymentMethodConverter}}" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="8" Text="مبلغ کل" Style="{StaticResource DetailLabel}" /><TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:N0}}" Style="{StaticResource DetailValue}" />
                </Grid>
            </Border>

            <TextBlock Text="برای مشاهده اطلاعات، یک سفارش را انتخاب کنید." Margin="0,10,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers><DataTrigger Binding="{Binding Details.Order}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="اقلام سفارش" Style="{StaticResource SectionTitle}" Margin="0,16,0,7" />
            <DataGrid ItemsSource="{Binding Details.ItemsPagination.Items}" Height="142">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="غذا" Binding="{Binding FoodName}" Width="*" />
                    <DataGridTextColumn Header="تعداد" Binding="{Binding Quantity}" Width="55" />
                    <DataGridTextColumn Header="قیمت واحد" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="90" />
                    <DataGridTextColumn Header="جمع" Binding="{Binding TotalPrice, StringFormat={}{0:N0}}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
            <controls:PaginationControl DataContext="{Binding Details.ItemsPagination}" />

            <TextBlock Text="تاریخچه وضعیت" Style="{StaticResource SectionTitle}" Margin="0,16,0,7" />
            <DataGrid ItemsSource="{Binding Details.StatusHistoriesPagination.Items}" Height="132">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="از" Binding="{Binding FromStatus, Converter={StaticResource OrderStatusConverter}}" Width="*" />
                    <DataGridTextColumn Header="به" Binding="{Binding ToStatus, Converter={StaticResource OrderStatusConverter}}" Width="*" />
                    <DataGridTextColumn Header="زمان" Binding="{Binding ChangedAt, StringFormat={}{0:g}}" Width="145" />
                </DataGrid.Columns>
            </DataGrid>
            <controls:PaginationControl DataContext="{Binding Details.StatusHistoriesPagination}" />

            <TextBlock Text="اقدامات سفارش" Style="{StaticResource SectionTitle}" Margin="0,16,0,7" />
            <UniformGrid Columns="3" HorizontalAlignment="Stretch">
                <Button Content="تایید" Background="{StaticResource SuccessBrush}" BorderBrush="{StaticResource SuccessBrush}"
                        Visibility="{Binding SelectedOrder.Status, Converter={StaticResource OrderStatusActionVisibilityConverter}, ConverterParameter=Confirm}"
                        Command="{Binding ConfirmOrderCommand}" CommandParameter="{Binding SelectedOrder}" />
                <Button Content="تحویل" Visibility="{Binding SelectedOrder.Status, Converter={StaticResource OrderStatusActionVisibilityConverter}, ConverterParameter=Deliver}"
                        Command="{Binding SetDeliveredCommand}" CommandParameter="{Binding SelectedOrder}" />
                <Button Content="لغو" Style="{StaticResource DangerButton}"
                        Visibility="{Binding SelectedOrder.Status, Converter={StaticResource OrderStatusActionVisibilityConverter}, ConverterParameter=Cancel}"
                        Command="{Binding CancelOrderCommand}" CommandParameter="{Binding SelectedOrder}" />
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
