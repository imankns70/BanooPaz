<UserControl x:Class="Kafgir.WPF.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Kafgir.WPF.Controls"
             xmlns:converters="clr-namespace:Kafgir.WPF.Converters"
             xmlns:views="clr-namespace:Kafgir.WPF.Views"
             FlowDirection="RightToLeft">
    <UserControl.Resources>
        <converters:AlternationIndexToRowNumberConverter x:Key="RowNumberConverter" />
        <converters:OrderStatusToPersianConverter x:Key="OrderStatusConverter" />
        <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Background="#CBD5E1" CornerRadius="12" Padding="3">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource BrandBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Track" Property="Opacity" Value="0.5" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" MinWidth="620" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="2*" MinWidth="390" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Right">
                            <TextBlock Text="سفارش‌ها" Style="{StaticResource PageTitle}" />
                            <TextBlock Text="جستجو و پیگیری سفارش‌های روزانه" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="تازه‌سازی خودکار" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,7,0" />
                            <ToggleButton Style="{StaticResource SwitchToggleStyle}" IsChecked="{Binding IsAutoRefreshEnabled, Mode=TwoWay}" />
                        </StackPanel>
                    </DockPanel>

                    <WrapPanel Grid.Row="1" VerticalAlignment="Bottom">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="وضعیت" Style="{StaticResource FormLabel}" />
                            <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" DisplayMemberPath="DisplayName" Width="165" />
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="شماره سفارش" Style="{StaticResource FormLabel}" />
                            <TextBox Text="{Binding OrderNumberSearch, UpdateSourceTrigger=PropertyChanged}" Width="125" />
                        </StackPanel>
                        <Button Content="جستجو" Command="{Binding RefreshCommand}" MinWidth="88" VerticalAlignment="Bottom" />
                        <TextBlock Text="در حال دریافت..." Foreground="{StaticResource BrandBrush}" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers><DataTrigger Binding="{Binding IsBusy}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </WrapPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding OrdersPagination.Items}"
                      SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                      AlternationCount="1000000"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="ردیف" Width="52" IsReadOnly="True"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock HorizontalAlignment="Center" Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTextColumn Header="شماره سفارش" Binding="{Binding OrderNumber}" Width="135" />
                    <DataGridTextColumn Header="نام مشتری" Binding="{Binding CustomerFullName}" Width="*" />
                    <DataGridTextColumn Header="وضعیت" Binding="{Binding Status, Converter={StaticResource OrderStatusConverter}}" Width="115" />
                    <DataGridTextColumn Header="تاریخ" Binding="{Binding CreatedAt, StringFormat={}{0:g}}" Width="145" />
                    <DataGridTextColumn Header="مبلغ" Binding="{Binding TotalAmount, StringFormat={}{0:N0}}" Width="115" />
                </DataGrid.Columns>
            </DataGrid>
            <controls:PaginationControl Grid.Row="3" DataContext="{Binding OrdersPagination}" />
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource SurfaceCard}" Padding="14">
            <views:OrderDetailsView />
        </Border>
    </Grid>
</UserControl>
