<Window x:Class="BanooPaz.Admin.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BanooPaz.Admin.Wpf.Converters"
        xmlns:views="clr-namespace:BanooPaz.Admin.Wpf.Views"
        Title="بانوپز - پنل مدیریت"
        Width="1450" Height="850" MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F4" FlowDirection="RightToLeft">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="#8B3A3A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AlternatingRowBackground" Value="#FFF3EC" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="BorderBrush" Value="#E4CFC4" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <views:LoginView DataContext="{Binding Login}"
                         Visibility="{Binding DataContext.IsAuthenticated, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="18,12" Background="#6D2E2E" CornerRadius="8" Margin="0,0,0,14">
                <DockPanel>
                    <TextBlock Text="بانوپز - پنل مدیریت" Foreground="White"
                               FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="مدیریت سفارش‌ها، غذاها و منوی روزانه" Foreground="#FFE5D7"
                               FontSize="13" HorizontalAlignment="Left" VerticalAlignment="Center" />
                </DockPanel>
            </Border>
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" FontSize="14">
                <TabItem Header="سفارش‌ها" Padding="20,8">
                    <views:OrdersView DataContext="{Binding Orders}" Margin="0,10,0,0" />
                </TabItem>
                <TabItem Header="غذاها" Padding="20,8">
                    <views:FoodsView DataContext="{Binding Foods}" Margin="0,10,0,0" />
                </TabItem>
                <TabItem Header="منوی روزانه" Padding="20,8">
                    <views:DailyMenuView DataContext="{Binding DailyMenu}" Margin="0,10,0,0" />
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
